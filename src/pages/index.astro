---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Website Company Profile',
    description:
      'Website bisnis yang memadukan citra profesional, performa cepat, dan struktur konten yang mudah dipahami calon klien.',
  },
  {
    title: 'Portal dan Sistem Internal',
    description:
      'Dashboard admin, portal pengguna, dan alur operasional yang disesuaikan untuk membantu tim bekerja lebih rapi dan terukur.',
  },
  {
    title: 'Integrasi dan Automasi',
    description:
      'Integrasi WhatsApp, formulir, pembayaran, dan automasi proses kerja agar aktivitas digital tidak lagi berjalan manual.',
  },
];

const process = [
  'Discovery untuk memahami tujuan bisnis, target audiens, dan kebutuhan utama.',
  'Penyusunan struktur halaman dan alur pesan agar website lebih mudah dipahami.',
  'Eksekusi desain dan pengembangan dengan fokus pada performa dan skalabilitas.',
];

const works = [
  {
    name: 'Company Profile untuk Brand Profesional',
    summary:
      'Dirancang untuk menampilkan positioning, layanan, dan bukti kerja secara lebih rapi agar calon klien cepat percaya.',
  },
  {
    name: 'Portal Operasional untuk Tim',
    summary:
      'Merapikan alur data, form, dan proses kerja internal supaya tim tidak bergantung pada proses manual yang berulang.',
  },
  {
    name: 'Website Layanan dengan Lead Funnel',
    summary:
      'Menggabungkan presentasi layanan, pengambilan lead, dan tindak lanjut yang lebih tertata dalam satu pengalaman digital.',
  },
];

const packages = [
  {
    name: 'Starter Profile',
    fit: 'Untuk bisnis yang butuh profil online rapi dan cepat siap tampil.',
    items: ['Homepage company profile', 'Struktur pesan layanan', 'CTA WhatsApp', 'SEO dasar'],
  },
  {
    name: 'Business Website',
    fit: 'Untuk brand yang butuh halaman lebih lengkap dan alur lead lebih jelas.',
    items: ['Multi halaman', 'Portfolio atau katalog layanan', 'Form / WhatsApp funnel', 'Optimasi performa'],
    featured: true,
  },
  {
    name: 'Custom System',
    fit: 'Untuk kebutuhan dashboard, portal, automasi, atau integrasi internal.',
    items: ['Analisis workflow', 'Dashboard admin', 'Integrasi API / form', 'Support pengembangan'],
  },
];

const whatsappBrief =
  'https://wa.me/6282114752228?text=Assalamu%60alaikum%20Heru%2C%20saya%20ingin%20diskusi%20project%20website%20BenuaTech.%0ANama%3A%0ABisnis%2Flembaga%3A%0AKebutuhan%3A%0ATarget%20launch%3A';
---

<Layout
  title="BenuaTech | Solusi Website dan Sistem Digital"
  description="BenuaTech membantu bisnis membangun company profile, website layanan, dan sistem digital yang cepat, rapi, dan siap berkembang."
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow hero-mobile-pill"><span></span> BenuaTech Digital Studio</span>
      <h1>Website bisnis yang rapi.</h1>
      <p>
        BenuaTech membantu brand dan bisnis membangun company profile, website layanan, dan sistem
        internal yang terasa lebih meyakinkan sejak kesan pertama.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={whatsappBrief}>Konsultasi Proyek</a>
        <a class="btn btn-secondary" href="/portfolio">Lihat Portfolio</a>
      </div>
      <div class="hero-mobile-strip">
        <article class="hero-mobile-chip">
          <span>01</span>
          <small>Website siap tampil</small>
          <strong>Company profile</strong>
        </article>
        <article class="hero-mobile-chip">
          <span>02</span>
          <small>Alur kontak</small>
          <strong>Lead lebih jelas</strong>
        </article>
      </div>
    </div>
    <div class="hero-stage">
      <article class="hero-badge hero-badge-top-left">
        <span class="hero-badge-icon">24/7</span>
        <span>
          <strong>Support arah project</strong>
          <small>Dari brief awal sampai struktur halaman.</small>
        </span>
      </article>

      <article class="hero-badge hero-badge-left hero-badge-compact">
        <span class="hero-badge-icon hero-badge-icon-accent">UI</span>
      </article>

      <article class="hero-badge hero-badge-right hero-badge-dark">
        <span class="hero-badge-icon hero-badge-icon-dark">ROI</span>
        <span>
          <strong>Lead & trust</strong>
          <small>Website disiapkan untuk membantu konversi.</small>
        </span>
      </article>

      <svg class="hero-arrow hero-arrow-top" viewBox="0 0 120 90" aria-hidden="true">
        <path d="M8 80 C 28 52, 45 30, 86 24" />
        <path d="M81 18 L 96 23 L 84 35" />
      </svg>

      <svg class="hero-arrow hero-arrow-right" viewBox="0 0 120 90" aria-hidden="true">
        <path d="M12 18 C 44 18, 72 34, 98 66" />
        <path d="M92 50 L 100 66 L 82 66" />
      </svg>

      <div class="hero-panel hero-panel-visual hero-flow-panel">
        <div class="hero-flow-header">
          <span class="hero-flow-kicker">Alur lead</span>
          <strong>Website bekerja sebagai jalur masuk calon klien.</strong>
        </div>
        <div class="hero-flow">
          <article class="hero-flow-step hero-flow-step-blue">
            <span class="hero-flow-icon">01</span>
            <div>
              <strong>Pengunjung datang</strong>
              <small>Dari Google, sosial media, atau referral.</small>
            </div>
          </article>
          <article class="hero-flow-step hero-flow-step-amber">
            <span class="hero-flow-icon">02</span>
            <div>
              <strong>Lead masuk</strong>
              <small>Website mengarahkan ke WhatsApp atau form.</small>
            </div>
          </article>
          <article class="hero-flow-step hero-flow-step-green">
            <span class="hero-flow-icon">03</span>
            <div>
              <strong>Deal berjalan</strong>
              <small>Diskusi kebutuhan, penawaran, lalu project dimulai.</small>
            </div>
          </article>
        </div>
        <div class="hero-flow-result">
          <span>Hasil</span>
          <strong>Kesan profesional, alur kontak lebih jelas.</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-elevated">
    <div class="section-heading">
      <span class="eyebrow">Layanan Inti</span>
      <h2>Solusi digital inti.</h2>
    </div>
    <div class="card-grid">
      {services.map((service) => (
        <article class="info-card info-card-feature">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-section section-elevated">
    <div>
      <span class="eyebrow">Tentang Kami</span>
      <h2>Tampil lebih kuat di digital.</h2>
      <p>
        Kami percaya website yang baik bukan hanya terlihat bagus. Ia harus mampu menjelaskan nilai
        bisnis dengan jelas, menumbuhkan rasa percaya, dan mendukung proses penjualan atau komunikasi
        bisnis dengan lebih lancar.
      </p>
      <p>
        Karena itu, kami tidak hanya membangun tampilan. Kami membantu merapikan pesan, struktur
        halaman, dan pengalaman pengguna agar website benar-benar bekerja untuk tujuan bisnis.
      </p>
    </div>
    <div class="quote-card">
      <p>
        "Pendekatan kami sederhana: pahami kebutuhan bisnis, rapikan pesan brand, lalu bangun
        pengalaman digital yang cepat, bersih, dan siap dipakai."
      </p>
    </div>
  </section>

  <section class="section section-elevated">
    <div class="section-heading">
      <span class="eyebrow">Cara Kerja</span>
      <h2>Mulai dari arah yang jelas.</h2>
    </div>
    <div class="card-grid">
      {process.map((item, index) => (
        <article class="info-card info-card-feature">
          <span class="card-label">Tahap {index + 1}</span>
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-elevated">
    <div class="section-heading section-heading-row">
      <div>
        <span class="eyebrow">Paket Layanan</span>
        <h2>Pilih scope yang paling pas.</h2>
      </div>
      <p>
        Harga final menyesuaikan kebutuhan halaman, fitur, konten, dan timeline. Kita mulai dari
        scope kecil yang jelas dulu agar estimasi lebih akurat.
      </p>
    </div>
    <div class="package-grid">
      {packages.map((item) => (
        <article class={`package-card info-card ${item.featured ? 'package-card-featured' : ''}`}>
          <span class="card-label">{item.featured ? 'Paling fleksibel' : 'Scope'}</span>
          <h3>{item.name}</h3>
          <p>{item.fit}</p>
          <ul class="package-list">
            {item.items.map((point) => <li>{point}</li>)}
          </ul>
          <a class="package-link" href={whatsappBrief}>Diskusikan paket</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-elevated">
    <div class="section-heading">
      <span class="eyebrow">Contoh Arah Proyek</span>
      <h2>Arah project yang relevan.</h2>
    </div>
    <div class="card-grid">
      {works.map((work) => (
        <article class="info-card info-card-accent">
          <h3>{work.name}</h3>
          <p>{work.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section cta-banner">
    <div>
      <span class="eyebrow">Mulai Sekarang</span>
      <h2>Mulai dari brief sederhana.</h2>
      <p>
        Kirim gambaran kebutuhanmu lewat WhatsApp. Nanti kita susun arah halaman, fitur, dan
        prioritas pengerjaan.
      </p>
    </div>
    <a class="btn btn-primary" href={whatsappBrief}>Chat WhatsApp</a>
  </section>
</Layout>
