---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Website Company Profile',
    description:
      'Website bisnis yang memadukan citra profesional, performa cepat, dan struktur konten yang mudah dipahami calon klien.',
  },
  {
    title: 'Portal dan Sistem Internal',
    description:
      'Dashboard admin, portal pengguna, dan alur operasional yang disesuaikan untuk membantu tim bekerja lebih rapi dan terukur.',
  },
  {
    title: 'Integrasi dan Automasi',
    description:
      'Integrasi WhatsApp, formulir, pembayaran, dan automasi proses kerja agar aktivitas digital tidak lagi berjalan manual.',
  },
];

const highlights = [
  'Struktur pesan brand yang lebih jelas dan meyakinkan',
  'Tampilan modern yang tetap fokus pada kenyamanan pengguna',
  'Fondasi teknis ringan, cepat, dan siap dikembangkan',
];

const process = [
  'Discovery untuk memahami tujuan bisnis, target audiens, dan kebutuhan utama.',
  'Penyusunan struktur halaman dan alur pesan agar website lebih mudah dipahami.',
  'Eksekusi desain dan pengembangan dengan fokus pada performa dan skalabilitas.',
];

const works = [
  {
    name: 'Company Profile untuk Brand Profesional',
    summary:
      'Dirancang untuk menampilkan positioning, layanan, dan bukti kerja secara lebih rapi agar calon klien cepat percaya.',
  },
  {
    name: 'Portal Operasional untuk Tim',
    summary:
      'Merapikan alur data, form, dan proses kerja internal supaya tim tidak bergantung pada proses manual yang berulang.',
  },
  {
    name: 'Website Layanan dengan Lead Funnel',
    summary:
      'Menggabungkan presentasi layanan, pengambilan lead, dan tindak lanjut yang lebih tertata dalam satu pengalaman digital.',
  },
];
---

<Layout
  title="BenuaTech | Solusi Website dan Sistem Digital"
  description="BenuaTech membantu bisnis membangun company profile, website layanan, dan sistem digital yang cepat, rapi, dan siap berkembang."
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">BenuaTech Digital Studio</span>
      <h1>Membangun website dan sistem digital yang membuat bisnis terlihat lebih matang sejak kesan pertama.</h1>
      <p>
        BenuaTech membantu brand, lembaga, dan bisnis menyiapkan company profile, website layanan,
        serta sistem internal dengan pendekatan yang strategis, visual yang kuat, dan fondasi teknis
        yang ringan.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/contact">Konsultasi Proyek</a>
        <a class="btn btn-secondary" href="/portfolio">Lihat Portfolio</a>
      </div>
    </div>
    <div class="hero-stage">
      <article class="hero-badge hero-badge-top-left">
        <span class="hero-badge-icon">24/7</span>
        <span>
          <strong>Support arah project</strong>
          <small>Dari brief awal sampai struktur halaman.</small>
        </span>
      </article>

      <article class="hero-badge hero-badge-top-right hero-badge-compact">
        <span class="hero-tool-logo">BT</span>
      </article>

      <article class="hero-badge hero-badge-left hero-badge-compact">
        <span class="hero-badge-icon hero-badge-icon-accent">UI</span>
      </article>

      <article class="hero-badge hero-badge-bottom-left">
        <span class="hero-badge-icon hero-badge-icon-accent">Pro</span>
        <span>
          <strong>Visual yang meyakinkan</strong>
          <small>Rapi, cepat, dan cocok untuk branding bisnis.</small>
        </span>
      </article>

      <article class="hero-badge hero-badge-right hero-badge-dark">
        <span class="hero-badge-icon hero-badge-icon-dark">ROI</span>
        <span>
          <strong>Lead & trust</strong>
          <small>Website disiapkan untuk membantu konversi.</small>
        </span>
      </article>

      <svg class="hero-arrow hero-arrow-top" viewBox="0 0 120 90" aria-hidden="true">
        <path d="M8 80 C 28 52, 45 30, 86 24" />
        <path d="M81 18 L 96 23 L 84 35" />
      </svg>

      <svg class="hero-arrow hero-arrow-right" viewBox="0 0 120 90" aria-hidden="true">
        <path d="M12 18 C 44 18, 72 34, 98 66" />
        <path d="M92 50 L 100 66 L 82 66" />
      </svg>

      <svg class="hero-arrow hero-arrow-bottom" viewBox="0 0 140 90" aria-hidden="true">
        <path d="M126 24 C 98 38, 74 58, 24 62" />
        <path d="M34 52 L 20 62 L 36 72" />
      </svg>

      <div class="hero-panel hero-panel-visual">
        <div class="hero-window">
          <div class="hero-window-dots">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="hero-code">
            <span class="hero-code-muted">// BenuaTech approach</span>
            <span><em>const</em> brand = &#123;</span>
            <span>&nbsp;&nbsp;clarity: <strong>'message-first'</strong>,</span>
            <span>&nbsp;&nbsp;design: <strong>'credible'</strong>,</span>
            <span>&nbsp;&nbsp;build: <strong>'fast and scalable'</strong>,</span>
            <span>&#125;;</span>
            <span class="hero-code-space"></span>
            <span><em>const</em> results = &#123;</span>
            <span>&nbsp;&nbsp;trust: <strong>'higher'</strong>,</span>
            <span>&nbsp;&nbsp;leads: <strong>'clearer'</strong>,</span>
            <span>&nbsp;&nbsp;experience: <strong>'smoother'</strong>,</span>
            <span>&#125;;</span>
          </div>
        </div>
        <div class="panel-metric">
          <p class="panel-kicker">Fokus utama</p>
          <ul class="panel-list">
            {highlights.map((item) => <li>{item}</li>)}
          </ul>
          <strong>Fast. Clear. Credible.</strong>
          <span>Dirancang untuk performa, kejelasan pesan, dan kesan profesional yang tahan lama.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Layanan Inti</span>
      <h2>Solusi digital yang disiapkan untuk kebutuhan yang paling sering menjadi bottleneck bisnis.</h2>
    </div>
    <div class="card-grid">
      {services.map((service) => (
        <article class="info-card">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div>
      <span class="eyebrow">Tentang Kami</span>
      <h2>BenuaTech hadir untuk membantu bisnis tampil lebih kuat di ranah digital.</h2>
      <p>
        Kami percaya website yang baik bukan hanya terlihat bagus. Ia harus mampu menjelaskan nilai
        bisnis dengan jelas, menumbuhkan rasa percaya, dan mendukung proses penjualan atau komunikasi
        bisnis dengan lebih lancar.
      </p>
      <p>
        Karena itu, kami tidak hanya membangun tampilan. Kami membantu merapikan pesan, struktur
        halaman, dan pengalaman pengguna agar website benar-benar bekerja untuk tujuan bisnis.
      </p>
    </div>
    <div class="quote-card">
      <p>
        "Pendekatan kami sederhana: pahami kebutuhan bisnis, rapikan pesan brand, lalu bangun
        pengalaman digital yang cepat, bersih, dan siap dipakai."
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Cara Kerja</span>
      <h2>Setiap project dimulai dari kejelasan arah, bukan dari menebak-nebak tampilan.</h2>
    </div>
    <div class="card-grid">
      {process.map((item, index) => (
        <article class="info-card">
          <span class="card-label">Tahap {index + 1}</span>
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Contoh Arah Proyek</span>
      <h2>Beberapa bentuk solusi yang paling relevan untuk menjadi pijakan portfolio BenuaTech.</h2>
    </div>
    <div class="card-grid">
      {works.map((work) => (
        <article class="info-card info-card-accent">
          <h3>{work.name}</h3>
          <p>{work.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section cta-banner">
    <div>
      <span class="eyebrow">Mulai Sekarang</span>
      <h2>Kalau kamu butuh web company profile atau sistem digital, kita bisa mulai dari brief yang sederhana dulu.</h2>
    </div>
    <a class="btn btn-primary" href="/contact">Hubungi BenuaTech</a>
  </section>
</Layout>
