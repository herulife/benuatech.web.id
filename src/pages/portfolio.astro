---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    category: 'Education Platform',
    title: 'Darussunnah Parung',
    description:
      'Website public-facing dan sistem digital untuk lembaga pendidikan, dengan fokus pada citra institusi, alur informasi, dan kebutuhan operasional.',
    impact: 'Fokus pada trust, struktur konten, dan pengalaman pengguna yang rapi.',
    link: 'https://darussunnahparung.com',
  },
  {
    category: 'Commerce Platform',
    title: 'Koalisi Cinta Buku',
    description:
      'Pengembangan website layanan dan katalog online yang menggabungkan presentasi produk, alur pembelian, dan pengalaman brand yang konsisten.',
    impact: 'Fokus pada kejelasan produk, funnel pengguna, dan performa frontend.',
    link: 'https://cintabuku.com',
  },
  {
    category: 'Company Profile Direction',
    title: 'BenuaTech Web Presence',
    description:
      'Perancangan identitas website company profile untuk menunjukkan arah brand, layanan, dan positioning digital yang lebih profesional.',
    impact: 'Fokus pada brand clarity, visual hierarchy, dan kesiapan pengembangan jangka panjang.',
    link: 'https://benuatech.web.id',
  },
];
---

<Layout
  title="Portfolio BenuaTech"
  description="Arah portfolio BenuaTech untuk website company profile, dashboard operasional, dan platform layanan digital."
>
  <section class="page-hero">
    <span class="eyebrow">Portfolio</span>
    <h1>Contoh studi kasus yang menggambarkan bagaimana BenuaTech membangun solusi digital yang terasa matang.</h1>
    <p>
      Halaman ini sekarang menampilkan contoh proyek nyata dan arah kerja yang relevan dengan layanan
      BenuaTech. Nanti kita masih bisa menambah screenshot, capaian, dan studi kasus yang lebih rinci.
    </p>
  </section>

  <section class="section">
    <div class="card-grid">
      {projects.map((project) => (
        <article class="info-card info-card-accent">
          <span class="card-label">{project.category}</span>
          <h2>{project.title}</h2>
          <p>{project.description}</p>
          <p><strong>{project.impact}</strong></p>
          <p><a href={project.link} target="_blank" rel="noreferrer">Kunjungi project</a></p>
        </article>
      ))}
    </div>
  </section>
</Layout>
