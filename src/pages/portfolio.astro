---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    category: 'Company Profile',
    title: 'Repositioning Website untuk Bisnis Jasa',
    description:
      'Penyusunan ulang halaman utama, layanan, dan CTA agar bisnis terlihat lebih premium serta lebih mudah menghasilkan lead.',
    impact: 'Fokus pada trust, struktur pesan, dan kejelasan layanan.',
  },
  {
    category: 'Internal System',
    title: 'Dashboard Operasional untuk Tim',
    description:
      'Sistem internal untuk mengurangi proses manual, merapikan data, dan mempercepat tindak lanjut antar bagian.',
    impact: 'Fokus pada efisiensi operasional dan visibilitas data.',
  },
  {
    category: 'Digital Service',
    title: 'Platform Layanan dengan Funnel yang Jelas',
    description:
      'Website layanan digital yang menyatukan presentasi produk, pengambilan lead, dan langkah tindak lanjut secara lebih terarah.',
    impact: 'Fokus pada pengalaman pengguna dan alur konversi.',
  },
];
---

<Layout
  title="Portfolio BenuaTech"
  description="Arah portfolio BenuaTech untuk website company profile, dashboard operasional, dan platform layanan digital."
>
  <section class="page-hero">
    <span class="eyebrow">Portfolio</span>
    <h1>Contoh studi kasus yang menggambarkan bagaimana BenuaTech membangun solusi digital yang terasa matang.</h1>
    <p>
      Untuk tahap awal, halaman ini disusun seperti format studi kasus. Nanti kita bisa mengganti isinya
      dengan proyek asli, screenshot, hasil sebelum-sesudah, dan capaian bisnis yang lebih spesifik.
    </p>
  </section>

  <section class="section">
    <div class="card-grid">
      {projects.map((project) => (
        <article class="info-card info-card-accent">
          <span class="card-label">{project.category}</span>
          <h2>{project.title}</h2>
          <p>{project.description}</p>
          <p><strong>{project.impact}</strong></p>
        </article>
      ))}
    </div>
  </section>
</Layout>
