---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BenuaTech',
  description = 'BenuaTech membantu bisnis membangun website company profile dan sistem digital yang cepat, rapi, dan siap berkembang.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/about', label: 'Tentang' },
  { href: '/services', label: 'Layanan' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Kontak' },
];
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/icon-benuatech.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="brand" href="/">
					<span class="brand-mark">
						<img src="/icon-benuatech.svg" alt="Logo BenuaTech" />
					</span>
					<span class="brand-copy">
						<strong>BenuaTech</strong>
						<small>Digital Studio</small>
					</span>
				</a>
				<nav class="site-nav">
					{navItems.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</nav>
			</header>
			<main class="page-shell">
				<slot />
			</main>
			<footer class="site-footer">
				<div>
					<strong>BenuaTech</strong>
					<p>Website dan sistem digital yang cepat, bersih, dan siap berkembang.</p>
				</div>
				<div class="footer-links">
					<a href="mailto:hello@benuatech.web.id">hello@benuatech.web.id</a>
					<a href="/contact">Diskusikan kebutuhanmu</a>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #f4efe5;
		--surface: rgba(255, 255, 255, 0.75);
		--surface-strong: #fffaf2;
		--text: #1f2937;
		--muted: #5f6b7a;
		--line: rgba(31, 41, 55, 0.12);
		--brand: #b45309;
		--brand-dark: #7c2d12;
		--accent: #0f766e;
		--shadow: 0 24px 60px rgba(80, 55, 20, 0.12);
	}

	html {
		font-family: Georgia, 'Times New Roman', serif;
		background:
			radial-gradient(circle at top left, rgba(180, 83, 9, 0.12), transparent 28%),
			radial-gradient(circle at top right, rgba(15, 118, 110, 0.12), transparent 24%),
			linear-gradient(180deg, #f7f1e8 0%, #f3ece2 100%);
		color: var(--text);
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 24px;
	}

	.site-header,
	.site-footer,
	.info-card,
	.hero-panel,
	.quote-card,
	.cta-banner {
		backdrop-filter: blur(18px);
		background: var(--surface);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.site-header,
	.site-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		padding: 18px 22px;
		border-radius: 24px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.brand-mark {
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.brand-mark img {
		display: block;
		width: 48px;
		height: 48px;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
	}

	.brand-copy strong,
	.site-nav,
	.btn,
	.card-label,
	.eyebrow {
		font-family: Arial, sans-serif;
	}

	.brand-copy small,
	.section-heading p,
	.info-card p,
	.hero-copy p,
	.page-hero p,
	.quote-card p,
	.site-footer p,
	.panel-metric span,
	.bullet-list,
	.panel-list {
		color: var(--muted);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		font-size: 0.95rem;
	}

	.site-nav a {
		padding: 10px 14px;
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.site-nav a:hover {
		background: rgba(180, 83, 9, 0.12);
		color: var(--brand-dark);
		transform: translateY(-1px);
	}

	.page-shell {
		padding: 36px 0 44px;
	}

	.hero,
	.split-section {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 24px;
		align-items: stretch;
	}

	.hero-copy,
	.page-hero {
		padding: 24px 0;
	}

	.hero-copy h1,
	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-size: clamp(2.6rem, 6vw, 5.4rem);
		line-height: 0.96;
		letter-spacing: -0.05em;
		margin: 0;
	}

	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-size: clamp(2rem, 4vw, 3.5rem);
	}

	.hero-copy p,
	.page-hero p,
	.split-section p {
		font-size: 1.05rem;
		line-height: 1.8;
		max-width: 62ch;
	}

	.eyebrow,
	.card-label,
	.panel-kicker {
		display: inline-block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--brand);
		margin-bottom: 14px;
		font-weight: 700;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 22px;
		border-radius: 999px;
		font-weight: 700;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
		color: white;
		box-shadow: 0 16px 36px rgba(124, 45, 18, 0.25);
	}

	.btn-secondary {
		background: rgba(15, 118, 110, 0.12);
		color: var(--accent);
	}

	.hero-panel,
	.quote-card,
	.info-card,
	.cta-banner {
		border-radius: 28px;
		padding: 28px;
	}

	.panel-list,
	.bullet-list {
		padding-left: 18px;
		line-height: 1.8;
	}

	.panel-metric {
		margin-top: 24px;
		padding-top: 22px;
		border-top: 1px solid var(--line);
		display: grid;
		gap: 8px;
	}

	.panel-metric strong {
		font-size: 1.35rem;
	}

	.section {
		margin-top: 52px;
	}

	.section-heading {
		margin-bottom: 20px;
	}

	.card-grid,
	.info-stack {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.info-stack {
		grid-template-columns: 1fr;
	}

	.info-card h2,
	.info-card h3 {
		margin: 0 0 12px;
		font-size: 1.5rem;
	}

	.info-card-accent {
		background:
			linear-gradient(180deg, rgba(255, 250, 242, 0.92) 0%, rgba(255, 245, 235, 0.82) 100%);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		background:
			linear-gradient(135deg, rgba(180, 83, 9, 0.12) 0%, rgba(15, 118, 110, 0.12) 100%),
			var(--surface-strong);
	}

	.site-footer {
		margin-top: 56px;
	}

	.footer-links {
		display: grid;
		gap: 10px;
		text-align: right;
		font-family: Arial, sans-serif;
	}

	@media (max-width: 900px) {
		.site-shell {
			padding: 16px;
		}

		.site-header,
		.site-footer,
		.hero,
		.split-section,
		.cta-banner,
		.card-grid {
			grid-template-columns: 1fr;
			flex-direction: column;
			align-items: flex-start;
		}

		.hero-copy h1,
		.page-hero h1,
		.section-heading h2,
		.split-section h2,
		.cta-banner h2 {
			font-size: clamp(2rem, 10vw, 3.5rem);
		}

		.site-nav {
			width: 100%;
		}

		.footer-links {
			text-align: left;
		}
	}
</style>
