---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BenuaTech',
  description = 'BenuaTech membantu bisnis membangun website company profile dan sistem digital yang cepat, rapi, dan siap berkembang.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/about', label: 'Tentang' },
  { href: '/services', label: 'Layanan' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Kontak' },
];
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/icon-benuatech.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<div class="header-main">
					<a class="brand" href="/">
						<span class="brand-mark">
							<img src="/icon-benuatech.svg" alt="Logo BenuaTech" width="48" height="48" />
						</span>
						<span class="brand-copy">
							<strong>BenuaTech</strong>
							<small>Digital Studio</small>
						</span>
					</a>
					<nav class="site-nav">
						{navItems.map((item) => (
							<a href={item.href}>{item.label}</a>
						))}
					</nav>
					<details class="mobile-nav">
						<summary>Menu</summary>
						<nav class="mobile-nav-panel">
							{navItems.map((item) => (
								<a href={item.href}>{item.label}</a>
							))}
						</nav>
					</details>
				</div>
			</header>
			<main class="page-shell">
				<slot />
			</main>
			<footer class="site-footer">
				<div>
					<strong>BenuaTech</strong>
					<p>Website dan sistem digital yang cepat, bersih, dan siap berkembang.</p>
				</div>
				<div class="footer-links">
					<a href="https://wa.me/6282114752228">Heru Fidiyanto - 0821 1475 2228</a>
					<a href="/contact">Diskusikan kebutuhanmu</a>
				</div>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f8fbff;
		--surface: rgba(255, 255, 255, 0.82);
		--surface-strong: #ffffff;
		--text: #0f172a;
		--muted: #526178;
		--line: rgba(30, 64, 175, 0.12);
		--brand: #2563eb;
		--brand-dark: #1e40af;
		--accent: #0891b2;
		--accent-soft: #e0f2fe;
		--shadow: 0 24px 60px rgba(30, 64, 175, 0.12);
		--font-sans: Aptos, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
		--asset-version: 2;
	}

	html {
		font-family: var(--font-sans);
		background:
			radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 28%),
			radial-gradient(circle at top right, rgba(8, 145, 178, 0.14), transparent 24%),
			linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
		color: var(--text);
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 24px;
	}

	.page-shell > * {
		animation: section-rise 0.55s ease both;
	}

	.page-shell > *:nth-child(2) {
		animation-delay: 0.04s;
	}

	.page-shell > *:nth-child(3) {
		animation-delay: 0.08s;
	}

	.site-header,
	.site-footer,
	.info-card,
	.hero-panel,
	.quote-card,
	.cta-banner {
		backdrop-filter: blur(18px);
		background: var(--surface);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.site-header,
	.site-footer {
		display: block;
		padding: 18px 22px;
		border-radius: 24px;
	}

	.header-main {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		position: relative;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.brand-mark {
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.brand-mark img {
		display: block;
		width: 48px;
		height: 48px;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
	}

	.brand-copy strong,
	.site-nav,
	.btn,
	.card-label,
	.eyebrow {
		font-family: var(--font-sans);
	}

	.brand-copy small,
	.section-heading p,
	.info-card p,
	.hero-copy p,
	.page-hero p,
	.quote-card p,
	.site-footer p,
	.hero-flow-step small,
	.bullet-list,
	.hero-flow-result span {
		color: var(--muted);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		font-size: 0.95rem;
	}

	.mobile-nav {
		display: none;
	}

	.site-nav a {
		padding: 10px 14px;
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.site-nav a:hover {
		background: rgba(37, 99, 235, 0.1);
		color: var(--brand-dark);
		transform: translateY(-1px);
	}

	.page-shell {
		padding: 36px 0 44px;
	}

	.hero,
	.split-section {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 24px;
		align-items: stretch;
	}

	.hero {
		align-items: center;
		grid-template-columns: minmax(0, 1fr) minmax(420px, 0.88fr);
		gap: 34px;
	}

	.hero-copy,
	.page-hero {
		padding: 24px 0;
	}

	.hero-stage {
		position: relative;
		min-height: 500px;
		padding: 34px 8px 18px;
	}

	.hero-copy h1,
	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-family: var(--font-sans);
		font-size: clamp(2.15rem, 4.15vw, 3.95rem);
		line-height: 1.04;
		letter-spacing: -0.04em;
		font-weight: 800;
		margin: 0;
	}

	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-size: clamp(2rem, 4vw, 3.5rem);
	}

	.hero-copy p,
	.page-hero p,
	.split-section p {
		font-size: 1.02rem;
		line-height: 1.78;
		max-width: 62ch;
	}

	.hero-copy {
		max-width: 34rem;
	}

	.hero-mobile-strip {
		display: none;
	}

	.eyebrow,
	.card-label {
		display: inline-block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--brand);
		margin-bottom: 14px;
		font-weight: 700;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 22px;
		border-radius: 999px;
		font-weight: 700;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
		color: white;
		box-shadow: 0 16px 36px rgba(37, 99, 235, 0.25);
	}

	.btn-secondary {
		background: var(--accent-soft);
		color: var(--accent);
	}

	.hero-panel,
	.quote-card,
	.info-card,
	.cta-banner {
		border-radius: 28px;
		padding: 28px;
	}

	.bullet-list {
		padding-left: 18px;
		line-height: 1.8;
	}

	.hero-panel-visual {
		position: relative;
		overflow: hidden;
		padding: 22px;
		min-height: 360px;
		width: min(100%, 390px);
		margin: 42px 0 0 auto;
		background:
			linear-gradient(135deg, rgba(30, 64, 175, 0.96) 0%, rgba(37, 99, 235, 0.9) 48%, rgba(8, 145, 178, 0.9) 100%);
		border: 1px solid rgba(255, 255, 255, 0.16);
	}

	.hero-panel-visual::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.09) 0%, transparent 38%),
			repeating-linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.06) 0,
				rgba(255, 255, 255, 0.06) 2px,
				transparent 2px,
				transparent 18px
			);
		pointer-events: none;
	}

	.hero-flow-panel {
		display: grid;
		gap: 16px;
		align-content: start;
	}

	.hero-flow-header,
	.hero-flow,
	.hero-flow-result {
		position: relative;
		z-index: 1;
	}

	.hero-flow-header {
		padding: 18px 18px 16px;
		border-radius: 22px;
		background: rgba(15, 23, 42, 0.86);
		color: #f8fafc;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}

	.hero-flow-kicker {
		display: block;
		margin-bottom: 8px;
		font-family: var(--font-sans);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #bae6fd;
	}

	.hero-flow-header strong {
		display: block;
		font-size: 1.35rem;
		line-height: 1.16;
		letter-spacing: -0.04em;
	}

	.hero-flow {
		display: grid;
		gap: 10px;
	}

	.hero-flow-step {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 12px;
		align-items: center;
		padding: 13px;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.94);
		border: 1px solid rgba(255, 255, 255, 0.38);
		box-shadow: 0 16px 36px rgba(5, 35, 40, 0.14);
	}

	.hero-flow-step strong,
	.hero-flow-step small {
		display: block;
		font-family: var(--font-sans);
	}

	.hero-flow-step strong {
		margin-bottom: 3px;
		font-size: 0.95rem;
		color: var(--text);
	}

	.hero-flow-step small {
		font-size: 0.8rem;
		line-height: 1.45;
	}

	.hero-flow-icon {
		display: grid;
		place-items: center;
		width: 42px;
		height: 42px;
		border-radius: 14px;
		font-family: var(--font-sans);
		font-size: 0.82rem;
		font-weight: 800;
		color: white;
	}

	.hero-flow-step-blue .hero-flow-icon {
		background: #2563eb;
	}

	.hero-flow-step-amber .hero-flow-icon {
		background: #1d4ed8;
	}

	.hero-flow-step-green .hero-flow-icon {
		background: #0891b2;
	}

	.hero-flow-result {
		display: grid;
		gap: 4px;
		padding: 14px 16px;
		border-radius: 18px;
		background: rgba(15, 23, 42, 0.72);
		border: 1px solid rgba(255, 255, 255, 0.12);
	}

	.hero-flow-result span {
		font-family: var(--font-sans);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.62);
	}

	.hero-flow-result strong {
		font-size: 1rem;
		line-height: 1.25;
		color: #f8fafc;
	}

	.hero-badge {
		position: absolute;
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 14px 18px;
		min-width: 178px;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.96);
		border: 1px solid rgba(255, 255, 255, 0.7);
		box-shadow: 0 22px 50px rgba(30, 64, 175, 0.14);
		backdrop-filter: blur(18px);
		animation: hero-float 6s ease-in-out infinite;
		transition: transform 0.28s ease, box-shadow 0.28s ease;
	}

	.hero-badge:hover {
		transform: translateY(-6px) scale(1.02);
		box-shadow: 0 28px 65px rgba(30, 64, 175, 0.2);
	}

	.hero-badge strong,
	.hero-badge small,
	.hero-tool-logo {
		font-family: var(--font-sans);
	}

	.hero-badge strong {
		display: block;
		margin-bottom: 3px;
		font-size: 1rem;
	}

	.hero-badge small {
		display: block;
		font-size: 0.86rem;
		line-height: 1.45;
		color: var(--muted);
	}

	.hero-badge-icon,
	.hero-tool-logo {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 16px;
		font-size: 0.92rem;
		font-weight: 800;
		color: #f8fafc;
		background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
	}

	.hero-badge-icon-accent {
		background: linear-gradient(135deg, #0891b2 0%, #1e40af 100%);
	}

	.hero-badge-icon-dark,
	.hero-badge-dark .hero-badge-icon {
		background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
	}

	.hero-tool-logo {
		width: 58px;
		height: 58px;
		font-size: 1rem;
		letter-spacing: 0.08em;
	}

	.hero-badge-compact {
		min-width: auto;
		padding: 12px;
		border-radius: 20px;
	}

	.hero-badge-dark {
		background: rgba(15, 23, 42, 0.96);
		color: #fff;
	}

	.hero-badge-dark small {
		color: rgba(255, 255, 255, 0.72);
	}

	.hero-badge-top-left {
		top: 8px;
		left: 6px;
		animation-delay: -0.5s;
	}

	.hero-badge-left {
		top: 198px;
		left: -12px;
		animation-delay: -2.2s;
	}

	.hero-badge-right {
		right: -18px;
		top: 252px;
		padding: 12px;
		gap: 0;
		min-width: auto;
		animation-delay: -2.8s;
	}

	.hero-badge-right > span:not(.hero-badge-icon) {
		display: none;
	}

	.hero-arrow {
		position: absolute;
		z-index: 2;
		width: 120px;
		height: 90px;
		overflow: visible;
		pointer-events: none;
	}

	.hero-arrow path {
		fill: none;
		stroke: #2563eb;
		stroke-width: 3.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-dasharray: 220;
		stroke-dashoffset: 220;
		animation: hero-arrow-draw 1.4s ease forwards;
	}

	.hero-arrow-top {
		top: 66px;
		left: -12px;
	}

	.hero-arrow-right {
		top: 208px;
		right: -76px;
	}

	.section {
		margin-top: 52px;
	}

	.section-elevated {
		position: relative;
		padding: 28px;
		border-radius: 32px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, rgba(239, 246, 255, 0.36) 100%);
		border: 1px solid rgba(255, 255, 255, 0.42);
		box-shadow: 0 20px 50px rgba(30, 64, 175, 0.08);
	}

	.section-elevated::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.07), transparent 35%, rgba(8, 145, 178, 0.07));
		pointer-events: none;
	}

	.section-heading {
		margin-bottom: 20px;
		position: relative;
		z-index: 1;
	}

	.card-grid,
	.info-stack,
	.portfolio-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.info-stack {
		grid-template-columns: 1fr;
	}

	.portfolio-grid {
		grid-template-columns: 1fr;
	}

	.portfolio-card {
		padding: 18px;
	}

	.portfolio-shot {
		display: block;
		margin-bottom: 18px;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid var(--line);
		box-shadow: 0 18px 40px rgba(31, 41, 55, 0.12);
	}

	.portfolio-shot img {
		display: block;
		width: 100%;
		height: auto;
	}

	.info-card h2,
	.info-card h3 {
		margin: 0 0 12px;
		font-size: 1.5rem;
	}

	.info-card {
		position: relative;
		z-index: 1;
		transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
	}

	.info-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 26px 54px rgba(30, 64, 175, 0.16);
		border-color: rgba(37, 99, 235, 0.18);
	}

	.info-card-feature::after {
		content: '';
		display: block;
		width: 54px;
		height: 3px;
		margin-top: 18px;
		border-radius: 999px;
		background: linear-gradient(90deg, var(--brand) 0%, rgba(8, 145, 178, 0.55) 100%);
	}

	.info-card-accent {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(239, 246, 255, 0.86) 100%);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		background:
			linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(8, 145, 178, 0.12) 100%),
			var(--surface-strong);
	}

	.site-footer {
		margin-top: 56px;
	}

	.footer-links {
		display: grid;
		gap: 10px;
		text-align: right;
		font-family: var(--font-sans);
	}

	@keyframes hero-float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@keyframes hero-arrow-draw {
		to {
			stroke-dashoffset: 0;
		}
	}

	@keyframes section-rise {
		from {
			opacity: 0.55;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 900px) {
		.site-shell {
			padding: 16px;
		}

		.site-footer,
		.hero,
		.split-section,
		.cta-banner,
		.card-grid {
			grid-template-columns: 1fr;
			flex-direction: column;
			align-items: flex-start;
		}

		.site-header {
			padding: 14px;
		}

		.header-main {
			gap: 12px;
			align-items: center;
		}

		.brand-mark,
		.brand-mark img {
			width: 46px;
			height: 46px;
		}

		.brand-copy strong {
			font-size: 1.05rem;
		}

		.brand-copy small {
			font-size: 0.84rem;
		}

		.hero-copy h1,
		.page-hero h1,
		.section-heading h2,
		.split-section h2,
		.cta-banner h2 {
			font-size: clamp(1.78rem, 8.8vw, 2.5rem);
			line-height: 1.02;
			letter-spacing: -0.04em;
		}

		.hero {
			gap: 18px;
		}

		.hero-copy {
			padding: 4px 0 0;
		}

		.hero-copy p {
			font-size: 1rem;
			line-height: 1.7;
		}

		.cta-row {
			width: 100%;
		}

		.cta-row .btn {
			flex: 1 1 100%;
			justify-content: center;
		}

		.hero-stage {
			min-height: auto;
			padding: 16px 0 0;
		}

		.hero-badge,
		.hero-arrow {
			display: none;
		}

		.hero-panel-visual {
			min-height: auto;
			width: 100%;
			margin: 18px 0 0;
			padding: 14px;
		}

		.hero-flow-panel {
			gap: 12px;
		}

		.hero-flow-header {
			padding: 15px;
			border-radius: 19px;
		}

		.hero-flow-header strong {
			font-size: 1.08rem;
		}

		.hero-flow-step {
			padding: 11px;
			border-radius: 16px;
		}

		.hero-flow-icon {
			width: 36px;
			height: 36px;
			border-radius: 12px;
			font-size: 0.74rem;
		}

		.hero-flow-step strong {
			font-size: 0.88rem;
		}

		.hero-flow-step small {
			font-size: 0.76rem;
			line-height: 1.35;
		}

		.hero-flow-result {
			padding: 12px 13px;
			border-radius: 16px;
		}

