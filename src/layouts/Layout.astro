---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BenuaTech',
  description = 'BenuaTech membantu bisnis membangun website company profile dan sistem digital yang cepat, rapi, dan siap berkembang.',
} = Astro.props;

const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/about', label: 'Tentang' },
  { href: '/services', label: 'Layanan' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Kontak' },
];
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/icon-benuatech.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<a class="brand" href="/">
					<span class="brand-mark">
						<img src="/icon-benuatech.svg" alt="Logo BenuaTech" />
					</span>
					<span class="brand-copy">
						<strong>BenuaTech</strong>
						<small>Digital Studio</small>
					</span>
				</a>
				<nav class="site-nav">
					{navItems.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</nav>
			</header>
			<main class="page-shell">
				<slot />
			</main>
			<footer class="site-footer">
				<div>
					<strong>BenuaTech</strong>
					<p>Website dan sistem digital yang cepat, bersih, dan siap berkembang.</p>
				</div>
				<div class="footer-links">
					<a href="https://wa.me/6282114752228">Heru Fidiyanto - 0821 1475 2228</a>
					<a href="/contact">Diskusikan kebutuhanmu</a>
				</div>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--bg: #f4efe5;
		--surface: rgba(255, 255, 255, 0.75);
		--surface-strong: #fffaf2;
		--text: #1f2937;
		--muted: #5f6b7a;
		--line: rgba(31, 41, 55, 0.12);
		--brand: #b45309;
		--brand-dark: #7c2d12;
		--accent: #0f766e;
		--shadow: 0 24px 60px rgba(80, 55, 20, 0.12);
	}

	html {
		font-family: Georgia, 'Times New Roman', serif;
		background:
			radial-gradient(circle at top left, rgba(180, 83, 9, 0.12), transparent 28%),
			radial-gradient(circle at top right, rgba(15, 118, 110, 0.12), transparent 24%),
			linear-gradient(180deg, #f7f1e8 0%, #f3ece2 100%);
		color: var(--text);
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 24px;
	}

	.site-header,
	.site-footer,
	.info-card,
	.hero-panel,
	.quote-card,
	.cta-banner {
		backdrop-filter: blur(18px);
		background: var(--surface);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.site-header,
	.site-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		padding: 18px 22px;
		border-radius: 24px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.brand-mark {
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.brand-mark img {
		display: block;
		width: 48px;
		height: 48px;
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
	}

	.brand-copy strong,
	.site-nav,
	.btn,
	.card-label,
	.eyebrow {
		font-family: Arial, sans-serif;
	}

	.brand-copy small,
	.section-heading p,
	.info-card p,
	.hero-copy p,
	.page-hero p,
	.quote-card p,
	.site-footer p,
	.panel-metric span,
	.bullet-list,
	.panel-list {
		color: var(--muted);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		font-size: 0.95rem;
	}

	.site-nav a {
		padding: 10px 14px;
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.site-nav a:hover {
		background: rgba(180, 83, 9, 0.12);
		color: var(--brand-dark);
		transform: translateY(-1px);
	}

	.page-shell {
		padding: 36px 0 44px;
	}

	.hero,
	.split-section {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 24px;
		align-items: stretch;
	}

	.hero {
		align-items: center;
		grid-template-columns: minmax(0, 1.08fr) minmax(460px, 0.92fr);
	}

	.hero-copy,
	.page-hero {
		padding: 24px 0;
	}

	.hero-stage {
		position: relative;
		min-height: 660px;
		padding: 54px 12px 38px;
	}

	.hero-copy h1,
	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-size: clamp(2.45rem, 5vw, 4.75rem);
		line-height: 0.98;
		letter-spacing: -0.05em;
		margin: 0;
	}

	.page-hero h1,
	.section-heading h2,
	.split-section h2,
	.cta-banner h2 {
		font-size: clamp(2rem, 4vw, 3.5rem);
	}

	.hero-copy p,
	.page-hero p,
	.split-section p {
		font-size: 1.05rem;
		line-height: 1.8;
		max-width: 62ch;
	}

	.hero-copy {
		max-width: 38rem;
	}

	.eyebrow,
	.card-label,
	.panel-kicker {
		display: inline-block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--brand);
		margin-bottom: 14px;
		font-weight: 700;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 22px;
		border-radius: 999px;
		font-weight: 700;
		transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
		color: white;
		box-shadow: 0 16px 36px rgba(124, 45, 18, 0.25);
	}

	.btn-secondary {
		background: rgba(15, 118, 110, 0.12);
		color: var(--accent);
	}

	.hero-panel,
	.quote-card,
	.info-card,
	.cta-banner {
		border-radius: 28px;
		padding: 28px;
	}

	.panel-list,
	.bullet-list {
		padding-left: 18px;
		line-height: 1.8;
	}

	.panel-metric {
		margin-top: 24px;
		padding-top: 22px;
		border-top: 1px solid var(--line);
		display: grid;
		gap: 8px;
	}

	.panel-metric strong {
		font-size: 1.35rem;
	}

	.hero-panel-visual {
		position: relative;
		overflow: hidden;
		padding: 26px;
		min-height: 430px;
		width: min(100%, 440px);
		margin: 74px 0 0 auto;
		background:
			linear-gradient(135deg, rgba(14, 116, 144, 0.94) 0%, rgba(15, 118, 110, 0.88) 52%, rgba(16, 69, 83, 0.96) 100%);
		border: 1px solid rgba(255, 255, 255, 0.16);
	}

	.hero-panel-visual::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.09) 0%, transparent 38%),
			repeating-linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.06) 0,
				rgba(255, 255, 255, 0.06) 2px,
				transparent 2px,
				transparent 18px
			);
		pointer-events: none;
	}

	.hero-window {
		position: relative;
		z-index: 1;
		border-radius: 24px;
		padding: 22px 24px;
		background: linear-gradient(180deg, rgba(10, 47, 55, 0.92) 0%, rgba(7, 41, 48, 0.98) 100%);
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
	}

	.hero-window-dots {
		display: flex;
		gap: 8px;
		margin-bottom: 18px;
	}

	.hero-window-dots span {
		display: inline-block;
		width: 10px;
		height: 10px;
		border-radius: 999px;
	}

	.hero-window-dots span:nth-child(1) {
		background: #fb7185;
	}

	.hero-window-dots span:nth-child(2) {
		background: #fbbf24;
	}

	.hero-window-dots span:nth-child(3) {
		background: #4ade80;
	}

	.hero-code {
		display: grid;
		gap: 10px;
		font-family: 'Courier New', monospace;
		font-size: 0.97rem;
		line-height: 1.75;
		color: #d7f9f1;
	}

	.hero-code em {
		font-style: normal;
		color: #f472b6;
	}

	.hero-code strong {
		color: #fde68a;
		font-weight: 700;
	}

	.hero-code-muted {
		color: rgba(216, 237, 232, 0.55);
	}

	.hero-code-space {
		height: 8px;
	}

	.hero-badge {
		position: absolute;
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 14px 18px;
		min-width: 178px;
		border-radius: 22px;
		background: rgba(255, 251, 245, 0.96);
		border: 1px solid rgba(255, 255, 255, 0.7);
		box-shadow: 0 22px 50px rgba(49, 31, 8, 0.14);
		backdrop-filter: blur(18px);
		animation: hero-float 6s ease-in-out infinite;
		transition: transform 0.28s ease, box-shadow 0.28s ease;
	}

	.hero-badge:hover {
		transform: translateY(-6px) scale(1.02);
		box-shadow: 0 28px 65px rgba(49, 31, 8, 0.2);
	}

	.hero-badge strong,
	.hero-badge small,
	.hero-tool-logo {
		font-family: Arial, sans-serif;
	}

	.hero-badge strong {
		display: block;
		margin-bottom: 3px;
		font-size: 1rem;
	}

	.hero-badge small {
		display: block;
		font-size: 0.86rem;
		line-height: 1.45;
		color: var(--muted);
	}

	.hero-badge-icon,
	.hero-tool-logo {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 52px;
		border-radius: 16px;
		font-size: 0.92rem;
		font-weight: 800;
		color: #f8fafc;
		background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
	}

	.hero-badge-icon-accent {
		background: linear-gradient(135deg, #0f766e 0%, #0f3f49 100%);
	}

	.hero-badge-icon-dark,
	.hero-badge-dark .hero-badge-icon {
		background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
	}

	.hero-tool-logo {
		width: 58px;
		height: 58px;
		font-size: 1rem;
		letter-spacing: 0.08em;
	}

	.hero-badge-compact {
		min-width: auto;
		padding: 12px;
		border-radius: 20px;
	}

	.hero-badge-dark {
		background: rgba(20, 27, 28, 0.96);
		color: #fff;
	}

	.hero-badge-dark small {
		color: rgba(255, 255, 255, 0.72);
	}

	.hero-badge-top-left {
		top: 0;
		left: 8px;
		animation-delay: -0.5s;
	}

	.hero-badge-top-right {
		top: -20px;
		right: -4px;
		animation-delay: -1.4s;
	}

	.hero-badge-left {
		top: 248px;
		left: -22px;
		animation-delay: -2.2s;
	}

	.hero-badge-bottom-left {
		left: 56px;
		bottom: 0;
		animation-delay: -1s;
	}

	.hero-badge-right {
		right: -48px;
		top: 338px;
		animation-delay: -2.8s;
	}

	.hero-arrow {
		position: absolute;
		z-index: 2;
		width: 120px;
		height: 90px;
		overflow: visible;
		pointer-events: none;
	}

	.hero-arrow path {
		fill: none;
		stroke: #dc2626;
		stroke-width: 3.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-dasharray: 220;
		stroke-dashoffset: 220;
		animation: hero-arrow-draw 1.4s ease forwards;
	}

	.hero-arrow-top {
		top: 86px;
		left: -22px;
	}

	.hero-arrow-right {
		top: 276px;
		right: -80px;
	}

	.hero-arrow-bottom {
		bottom: 26px;
		right: 136px;
	}

	.section {
		margin-top: 52px;
	}

	.section-heading {
		margin-bottom: 20px;
	}

	.card-grid,
	.info-stack,
	.portfolio-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.info-stack {
		grid-template-columns: 1fr;
	}

	.portfolio-grid {
		grid-template-columns: 1fr;
	}

	.portfolio-card {
		padding: 18px;
	}

	.portfolio-shot {
		display: block;
		margin-bottom: 18px;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid var(--line);
		box-shadow: 0 18px 40px rgba(31, 41, 55, 0.12);
	}

	.portfolio-shot img {
		display: block;
		width: 100%;
		height: auto;
	}

	.info-card h2,
	.info-card h3 {
		margin: 0 0 12px;
		font-size: 1.5rem;
	}

	.info-card-accent {
		background:
			linear-gradient(180deg, rgba(255, 250, 242, 0.92) 0%, rgba(255, 245, 235, 0.82) 100%);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		background:
			linear-gradient(135deg, rgba(180, 83, 9, 0.12) 0%, rgba(15, 118, 110, 0.12) 100%),
			var(--surface-strong);
	}

	.site-footer {
		margin-top: 56px;
	}

	.footer-links {
		display: grid;
		gap: 10px;
		text-align: right;
		font-family: Arial, sans-serif;
	}

	@keyframes hero-float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@keyframes hero-arrow-draw {
		to {
			stroke-dashoffset: 0;
		}
	}

	@media (max-width: 900px) {
		.site-shell {
			padding: 16px;
		}

		.site-header,
		.site-footer,
		.hero,
		.split-section,
		.cta-banner,
		.card-grid {
			grid-template-columns: 1fr;
			flex-direction: column;
			align-items: flex-start;
		}

		.hero-copy h1,
		.page-hero h1,
		.section-heading h2,
		.split-section h2,
		.cta-banner h2 {
			font-size: clamp(2rem, 10vw, 3.5rem);
		}

		.hero-stage {
			min-height: auto;
			padding: 12px 0 0;
		}

		.hero-badge,
		.hero-arrow {
			display: none;
		}

		.hero-panel-visual {
			min-height: auto;
		}

		.site-nav {
			width: 100%;
		}

		.footer-links {
			text-align: left;
		}
	}
</style>
